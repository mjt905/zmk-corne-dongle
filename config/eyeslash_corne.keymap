#define ZMK_POINTING_DEFAULT_MOVE_VAL 1200  // 600
#define ZMK_POINTING_DEFAULT_SCRL_VAL 25   // 10

#include <input/processors.dtsi>
#include <zephyr/dt-bindings/input/input-event-codes.h>
#include <behaviors.dtsi>
#include <dt-bindings/zmk/bt.h>
#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/pointing.h>
#include <dt-bindings/zmk/rgb.h>

&mmv_input_listener { input-processors = <&zip_xy_scaler 2 1>; };

&msc_input_listener { input-processors = <&zip_scroll_scaler 2 1>; };

&msc {
    acceleration-exponent = <1>;      // 0
    time-to-max-speed-ms = <100>;       // 300
    delay-ms = <0>;                   // 0
};

&mmv {
    time-to-max-speed-ms = <500>;
    acceleration-exponent = <1>;
    trigger-period-ms = <16>;
};

&soft_off { hold-time-ms = <2000>; };

/ {
    behaviors {
        td0: td0 {
            compatible = "zmk,behavior-tap-dance";
            display-name = "Shift/Caps Lock Tap Dance";
            #binding-cells = <0>;
            bindings = <&kp Z>, <&kp F14>;

            tapping-term-ms = <130>;
        };

        NandComma: NandComma {
            compatible = "zmk,behavior-mod-morph";
            label = "NANDCOMMA";
            bindings = <&kp N>, <&kp RS(COMMA)>;

            #binding-cells = <0>;
            mods = <(MOD_RSFT)>;
        };

        MandPeriod: MandPeriod {
            compatible = "zmk,behavior-mod-morph";
            label = "MANDPERIOD";
            bindings = <&kp M>, <&kp RS(PERIOD)>;

            #binding-cells = <0>;
            mods = <(MOD_RSFT)>;
        };

        f_ctrl: f_ctrl {
            compatible = "zmk,behavior-hold-tap";
            label = "F_CTRL";
            bindings = <&kp>, <&kp>;

            #binding-cells = <2>;
            tapping-term-ms = <170>;
            quick-tap-ms = <125>;
            require-prior-idle-ms = <125>;
            flavor = "balanced";
            hold-while-undecided;
            hold-trigger-key-positions = <1 15 16 17 18 5 4 3 2 29 30 31 32 33 36 22 7 9 8 23 24 38 37 39 25 10 11 26 40 44 43 42 45 46 47>;
        };

        NEW_LT: NEW_LT {
            compatible = "zmk,behavior-hold-tap";
            label = "NEW_LT";
            bindings = <&mo>, <&kp>;

            #binding-cells = <2>;
            tapping-term-ms = <170>;
            flavor = "balanced";
            quick-tap-ms = <125>;
        };
    };

    rgb_encoder: rgb_encoder {
        compatible = "zmk,behavior-sensor-rotate";
        #sensor-binding-cells = <0>;
        bindings = <&rgb_ug RGB_BRI>, <&rgb_ug RGB_BRD>;
    };

    scroll_encoder: scroll_encoder {
        compatible = "zmk,behavior-sensor-rotate";
        #sensor-binding-cells = <0>;
        bindings = <&msc SCRL_DOWN>, <&msc SCRL_UP>;

        tap-ms = <100>;
    };

    combos {
        compatible = "zmk,combos";

        softoff {
            bindings = <&soft_off>;
            key-positions = <0 13 28>;
            layers = <0>;
        };

        tab {
            bindings = <&kp TAB>;
            key-positions = <1 14>;
            layers = <0>;
        };

        backspace {
            bindings = <&kp BACKSPACE>;
            key-positions = <4 5>;
            layers = <2 1 0>;
            timeout-ms = <30>;
        };

        rightbackspace {
            bindings = <&kp BACKSPACE>;
            key-positions = <10 11>;
            layers = <0 2 1>;
            timeout-ms = <50>;
        };

        paste {
            bindings = <&kp LC(V)>;
            key-positions = <17 32>;
            layers = <0>;
        };

        esc {
            bindings = <&kp ESCAPE>;
            key-positions = <2 1>;
            layers = <0>;
        };

        del {
            bindings = <&kp DEL>;
            key-positions = <17 18>;
            layers = <0>;
        };

        caps {
            bindings = <&kp CAPS>;
            key-positions = <15 2>;
            layers = <0>;
        };

        ALT {
            bindings = <&kp LEFT_ALT>;
            key-positions = <3 16>;
            layers = <0>;
        };
    };

    keymap {
        compatible = "zmk,keymap";

        default_layer {
            display-name = "QWERTY";
            bindings = <
&trans  &kp Q        &kp W  &kp E           &kp R            &kp T                               &kp UP                &kp Y        &kp U        &kp I          &kp O      &kp P            &none
&none   &NEW_LT 3 A  &kp S  &kp D           &f_ctrl LCTRL F  &kp G                     &kp LEFT  &kp ENTER  &kp RIGHT  &kp H        &kp J        &kp K          &kp L      &kp BACKSPACE    &none
&none   &td0         &kp X  &kp C           &NEW_LT 4 V      &kp B        &kp SPACE              &kp DOWN              &NandComma   &MandPeriod  &kp SLASH      &kp GRAVE  &kp RIGHT_SHIFT  &none
                            &lt 5 LEFT_GUI  &lt 2 SPACE      &lt 1 ENTER                                               &lt 2 ENTER  &lt 1 SPACE  &kp RIGHT_ALT
            >;

            sensor-bindings = <&inc_dec_kp RIGHT_BRACKET LEFT_BRACKET>;
        };

        lower_layer {
            display-name = "NUMBER";
            bindings = <
&none  &kp NUMBER_1           &kp NUMBER_2  &kp NUMBER_3  &kp NUMBER_4  &kp N5                                   &mmv MOVE_UP                     &kp SQT    &kp LEFT_PARENTHESIS  &kp RIGHT_PARENTHESIS  &kp MINUS  &kp EQUAL        &none
&none  &kp NUMBER_6           &kp N7        &kp N8        &kp N9        &kp N0                   &mmv MOVE_LEFT  &mkp LCLK       &mmv MOVE_RIGHT  &kp SEMI   &kp LBKT              &kp RBKT               &kp BSLH   &kp RIGHT_SHIFT  &none
&none  &mt LEFT_SHIFT KP_DOT  &kp EQUAL     &kp MINUS     &kp ASTERISK  &kp SLASH  &kp C_MUTE                    &mmv MOVE_DOWN                   &kp COMMA  &kp DOT               &kp FSLH               &kp GRAVE  &kp ENTER        &none
                                            &none         &trans        &kp ENTER                                                                 &kp ENTER  &trans                &trans
            >;

            sensor-bindings = <&scroll_encoder>;
        };

        raise_layer {
            display-name = "FN";
            bindings = <
&none  &kp CAPSLOCK    &kp F1  &kp F2   &kp F3        &kp F4                               &mmv MOVE_UP                     &kp PAGE_UP    &kp HOME  &kp UP    &kp END    &kp INSERT  &none
&none  &kp LA(TAB)     &kp F5  &kp F6   &kp F7        &kp F8               &mmv MOVE_LEFT  &mkp LCLK       &mmv MOVE_RIGHT  &kp PAGE_DOWN  &kp LEFT  &kp DOWN  &kp RIGHT  &kp RSHFT   &none
&none  &kp LEFT_SHIFT  &kp F9  &kp F10  &kp F11       &kp F12    &trans                    &mmv MOVE_DOWN                   &kp F5         &kp F6    &kp F7    &to 6      &to 7       &none
                               &trans   &kp LEFT_ALT  &kp ENTER                                                             &trans         &trans    &trans
            >;

            sensor-bindings = <&scroll_encoder>;
        };

        little {
            bindings = <
&none   &kp LA(F4)      &mkp MB2        &kp UP_ARROW    &mkp MB1         &msc SCRL_UP                      &trans          &trans        &trans        &studio_unlock  &bt BT_CLR_ALL  &bt BT_CLR    &mo 1
&trans  &none           &kp LEFT_ARROW  &kp DOWN_ARROW  &kp RIGHT_ARROW  &msc SCRL_DOWN            &trans  &trans  &trans  &trans        &trans        &trans          &trans          &trans        &to 6
&none   &kp LEFT_SHIFT  &none           &trans          &kp F13          &none           &trans            &trans          &bt BT_SEL 0  &bt BT_SEL 1  &bt BT_SEL 2    &bt BT_SEL 3    &bt BT_SEL 4  &trans
                                        &kp COMMA       &kp PERIOD       &kp GRAVE                                         &trans        &trans        &trans
            >;

            label = "Arrow";
        };

        win {
            bindings = <
&trans  &kp LG(NUMBER_1)  &kp LG(NUMBER_2)  &kp LG(NUMBER_3)  &kp LG(NUMBER_4)  &none                     &trans          &trans  &trans  &trans  &trans  &trans  &trans
&trans  &kp LC(LS(TAB))   &kp LC(T)         &kp LC(TAB)       &trans            &trans            &trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans
&trans  &kp LC(L)         &kp LC(W)         &kp LA(TAB)       &trans            &trans  &trans            &trans          &trans  &trans  &trans  &trans  &trans  &trans
                                            &trans            &trans            &trans                                    &trans  &trans  &trans
            >;

            label = "Win";
        };

        RtoL {
            bindings = <
&trans  &kp P      &kp O     &kp I     &kp U   &kp Y                     &trans          &trans  &trans  &trans  &trans  &trans  &trans
&trans  &kp ENTER  &kp L     &kp K     &kp J   &kp H             &trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans
&trans  &kp LCTRL  &kp LALT  &kp LGUI  &kp M   &kp N   &trans            &trans          &trans  &trans  &trans  &trans  &trans  &trans
                             &trans    &trans  &trans                                    &trans  &trans  &trans
            >;

            label = "RtoL";
        };

        FPS {
            bindings = <
&none  &kp ESCAPE      &kp Q  &kp W      &kp E      &kp R                           &trans          &kp Y         &kp U   &kp I   &kp O   &trans  &kp BSPC
&none  &kp TAB         &kp A  &kp S      &kp D      &kp F                   &trans  &trans  &trans  &kp H         &kp J   &kp K   &kp L   &trans  &kp ENTER
&none  &kp LEFT_SHIFT  &kp Z  &kp X      &kp C      &kp V         &trans            &trans          &kp B         &kp N   &kp M   &trans  &to 1   &to 2
                              &kp LCTRL  &kp SPACE  &kp LEFT_ALT                                    &kp LEFT_GUI  &trans  &trans
            >;

            label = "FPS";
        };

        LOL {
            bindings = <
&trans  &kp ESCAPE      &kp NUMBER_1  &kp NUMBER_2  &kp NUMBER_3  &kp NUMBER_4                    &trans          &trans         &trans  &trans  &trans  &trans  &trans
&trans  &kp TAB         &kp Q         &kp W         &kp E         &kp R                   &trans  &trans  &trans  &trans         &trans  &trans  &trans  &trans  &trans
&trans  &kp LEFT_SHIFT  &kp A         &kp S         &kp D         &kp F         &trans            &trans          &trans         &trans  &trans  &trans  &to 1   &trans
                                      &kt B         &kp SPACE     &kp LCTRL                                       &kp RIGHT_ALT  &trans  &trans
            >;

            label = "LOL";
        };
    };
};
